# DairyPro 360 — Local Development Environment
# SQLite mode: no PostgreSQL or Redis needed

SECRET_KEY=dev-insecure-key-dairypro-360-change-in-production
DEBUG=True
USE_SQLITE=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL (for CORS)
FRONTEND_ORIGIN=http://localhost:3000

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (console backend used in dev — prints to terminal)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=DairyPro 360 <noreply@dairypro.com>
